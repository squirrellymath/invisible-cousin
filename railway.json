{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @workspace/invisible-cousin build"
  },
  "deploy": {
    "startCommand": "npx serve /app/artifacts/invisible-cousin/dist -l $PORT",
    "watchPatterns": ["/artifacts/invisible-cousin/**"]
  }
}
